# Local infrastructure defaults for Makefile-driven workflows.

PROJECT_NAME=skills_talk_agent_camp_2026
MLFLOW_HOST_PORT=5002
CHROMA_HOST_PORT=8000
CHROMA_BASE_URL=http://127.0.0.1:8000

# ClickHouse seed defaults.
GITHUB_ARCHIVE_TARGET_ROWS=5002000
GITHUB_ARCHIVE_SOURCE_SUFFIXES=aa ab ac ad ae af ag

# ── OpenAI provider ───────────────────────────────────────────────────────────
# Set to "azure" to use Azure OpenAI, "openai" for default OpenAI.
OPENAI_PROVIDER=openai
OPENAI_MODEL=gpt-4o

# Default OpenAI (used when OPENAI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Azure OpenAI (used when OPENAI_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Agent / ChromaDB ─────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5002
MLFLOW_EXPERIMENT_NAME=ghost-contributors-demo

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=WARNING
